<section class="grid md:grid-cols-3 2xl:grid-cols-4 m-auto gap-[2px] bg-wu-white">
  {% for product in collection.products limit: 48 %}
    {% assign remainder = forloop.length | modulo: 3 %}
    {% assign base_col = product.handle | split: "-" | last %}
    {% liquid 
      assign bgclass = "bg-wu-blue"
      assign txinv = "text-wu-white"
      assign txclass = "text-wu-blue"

      case base_col
      when "red"
        assign bgclass = "bg-wu-red"
        assign txclass = "text-wu-red"
      when "green"
        assign bgclass = "bg-wu-green"
        assign txclass = "text-wu-green"
      when "blue"
        assign bgclass = "bg-wu-blue"
        assign txclass = "text-wu-blue"
      when "turquoise"
        assign bgclass = "bg-wu-turquoise"
        assign txclass = "text-wu-turquoise"
      when "yellow"
        assign bgclass = "bg-wu-yellow"
        assign txclass = "text-wu-yellow"
      when "black"
        assign bgclass = "bg-wu-black"
        assign txclass = "text-wu-black"
      when "white"
        assign bgclass = "bg-wu-white"
        assign txinv = "text-wu-black"
        assign txclass = "text-wu-white"
      endcase
      %}

      {% liquid 
        assign bgclass = "bg-wu-blue"
        assign txinv = "text-wu-white"
        assign txclass = "text-wu-blue"
  
        case base_col
        when "red"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-red"
        when "green"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-green"
        when "blue"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-blue"
        when "turquoise"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-turquoise"
        when "yellow"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-yellow"
        when "black"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-black"
        when "white"
          assign bgclass = "bg-wu-black"
          assign txinv = "text-wu-white"
          assign txclass = "text-wu-white"
        endcase
        %}

        {% liquid 
          assign bgclass = "bg-wu-blue"
          assign txinv = "text-wu-white"
          assign txclass = "text-wu-white"

          case base_col
          when "white"
            assign txclass = "text-wu-black"
            assign borderclass = "border-wu"
          endcase
      %}
  

      <div class="grid {{ bgclass }} relative group">
      {%liquid 
        assign front_image = product.featured_image
        for image in product.images 
          if image.src contains "_front"
            assign front_image = image
            break
          endif
        endfor
      %}
      {% assign title_color = product.title | split: " " | last %}
      {% assign plain_title = product.title | remove: title_color | strip %}
    
      <a href="{{ product.url | within: collection }}" class="w-full block relative">

        <div class="">
          <img class="block md:group-hover:hidden w-full h-[36rem] md:h-80 xl:h-96 object-cover object-bottom p-0" src="{{ product.featured_image.src | img_url: '800x' }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" 
            srcset="{% render 'attr-srcset' with product.featured_image as image, widths: '400,800,1200' %}"
            sizes="(min-width: 768px) 35vw, (min-width: 1536px) 25vw, 100vw"
          >
          <img class="hidden group-hover:block w-full h-[36rem] md:h-80 xl:h-96 object-cover object-bottom p-0" src="{{ front_image.src | img_url: '800x' }}" alt="{{ front_image.alt | escape }}" loading="lazy">
        </div>

        <!-- <div class=" xaspect-h-1 xaspect-w-1 tag-{{ product.tags | join: ' tag-' }}">
          <img class="hidden md:block group-hover:hidden w-full h-[36rem] md:h-80 xl:h-96 object-cover object-bottom p-0" src="{{ front_image.src | img_url: '800x' }}" alt="{{ front_image.alt | escape }}" loading="lazy">
          <img class="block md:hidden md:group-hover:block w-full h-[36rem] md:h-80 xl:h-96 object-cover object-bottom p-0" src="{{ product.featured_image.src | img_url: '800x' }}" alt="{{ product.featured_image.alt | escape }}" xloading="lazy" 
            srcset="{% render 'attr-srcset' with product.featured_image as image, widths: '400,800,1200' %}"
            sizes="(min-width: 768px) 35vw, (min-width: 1536px) 25vw, 100vw"
          >
        </div> -->


      </a>
      <!-- <a class="transition-opacity md:opacity-0 group-hover:opacity-100 font-bold text-center absolute w-full bottom-0 p-4 block {{ bgclass }} {{txclass}}" href="{{ product.url | within: collection }}">{{ product.title }}</a> -->
      <div class="
        transition-opacity 
        md:opacity-0 group-hover:opacity-100 
        font-bold text-center 
        absolute w-full bottom-0 p-4 {{ txclass }} bg-{{ base_col }}">
        <a class="border-0 border-b border-current border-dashed pb-2" href="{{ product.url | within: collection }}">{{ plain_title }}</a>
      </div>
  
    </div>
  {% endfor %}
  <!-- padding for justification -->
  <div class="grid bg-wu-green"></div>
  <div class="grid bg-wu-black"></div>
  <div class="grid bg-wu-red"></div>

{% unless remainder == 0 %}
  {% for i in (remainder..2) %}
    <div class="hidden md:grid items-center justify-center  {% cycle 'bg': 'bg-purple-400', 'bg-green-200', 'bg-blue-700' %} text-5xl {% cycle 'col': 'text-red-500', 'text-blue-500' %} font-black aspect-h-1 aspect-w-1"> </div>
  {% endfor %}
  {% endunless %}
  </section>
