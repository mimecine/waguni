<section class="grid md:grid-cols-3 2xl:grid-cols-4 m-auto gap-[2px] bg-wu-white">
  {% for product in collection.products limit: 48 %}
    {% assign remainder = forloop.length | modulo: 3 %}
    {% assign base_col = product.handle | split: "-" | last %}
    {% liquid 
      assign bgclass = "bg-wu-blue"
      assign txinv = "text-wu-white"
      assign txclass = "text-wu-blue"

      case base_col
      when "red"
        assign bgclass = "bg-wu-red"
        assign txclass = "text-wu-red"
      when "green"
        assign bgclass = "bg-wu-green"
        assign txclass = "text-wu-green"
      when "blue"
        assign bgclass = "bg-wu-yellow"
        assign txclass = "text-wu-blue"
      when "turquoise"
        assign bgclass = "bg-wu-green"
        assign txclass = "text-wu-turquoise"
      when "yellow"
        assign bgclass = "bg-wu-green"
        assign txclass = "text-wu-yellow"
      when "black"
        assign bgclass = "bg-wu-blue"
        assign txclass = "text-wu-black"
      when "white"
        assign bgclass = "bg-wu-red"
        assign txinv = "text-wu-black"
        assign txclass = "text-wu-white"
      endcase
      %}

      {% comment %}
      {% liquid 
        assign bgclass = "bg-wu-blue"
        assign txinv = "text-wu-white"
        assign txclass = "text-wu-blue"
  
        case base_col
        when "red"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-red"
        when "green"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-green"
        when "blue"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-blue"
        when "turquoise"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-turquoise"
        when "yellow"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-yellow"
        when "black"
          assign bgclass = "bg-wu-white"
          assign txclass = "text-wu-black"
        when "white"
          assign bgclass = "bg-wu-black"
          assign txinv = "text-wu-white"
          assign txclass = "text-wu-white"
        endcase
        %}
        {% endcomment %}
        {% liquid 
          assign xx_bgclass = "bg-wu-blue"
          assign txinv = "text-wu-white"
          assign txclass = "text-wu-white"

          case base_col
          when "white"
            assign txclass = "text-wu-black"
            assign borderclass = "border-wu"
          endcase
      %}
  

      <div class="grid {{ bgclass }} relative group xpx-[40px] xpy-[25px] xhover:px-0 xhover:py-0">
      {%liquid 
        assign front_image = product.featured_image
        assign hover_image = product.featured_image
        for image in product.images 
          if image.src contains "_front"
            assign hover_image = image
            break
          endif
        endfor
        assign hover_image = product.images[1]
      %}
      {% assign title_color = product.title | split: " " | last %}
      {% assign plain_title = product.title | remove: title_color | strip %}
    
      <a href="{{ product.url | within: collection }}" class="w-full block relative">

        <div class="w-full aspect-w-4 aspect-h-5">
          <img  class="block md:group-hover:hidden object-cover xp-0 px-[40px] py-[25px]" 
                src="{{ front_image.src | img_url: '80x100', crop:'center' }}" alt="{{ front_image.alt | escape }}" 
                width="80" height="100" 
                loading="lazy"
                srcset="{% render 'attr-srcset' with front_image as image, widths: '400,800,1200', aspect_ratio: '4:5', crop: 'center' %}"
                sizes="(min-width: 768px) 33vw, (min-width: 1536px) 25vw, 100vw">
          <img  class="hidden md:group-hover:block object-cover p-0" 
                src="{{ hover_image.src | img_url: '80x100', crop:'center' }}" alt="{{ hover_image.alt | escape }}"
                width="80" height="100" 
                loading="lazy" 
                srcset="{% render 'attr-srcset' with hover_image as image, widths: '400,800,1200', aspect_ratio: '4:5', crop: 'center' %}"
                sizes="(min-width: 768px) 33vw, (min-width: 1536px) 25vw, 100vw">
        </div>
      </a>
      <div class="
        xtransition-opacity 
        md:opacity-0 group-hover:opacity-100 
        font-bold text-center 
        absolute w-full bottom-[40px] {{ txclass }} bg-transparent xbg-{{ base_col }}">
        <a class="pb-2 pt-3 px-4 h-[40px] bg-wu-white text-wu-blue text-[16px] lg:text-[20px]" href="{{ product.url | within: collection }}">{{ plain_title }}</a>
      </div>

    </div>
  {% endfor %}
  <!-- padding for justification -->
  <div class="grid bg-wu-green"></div>
  <div class="grid bg-wu-blue"></div>
  <div class="grid bg-wu-red"></div>
  <div class="grid bg-wu-green"></div>
  <div class="grid bg-wu-blue"></div>
  <div class="grid bg-wu-red"></div>

  </section>
