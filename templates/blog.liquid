{% paginate blog.articles by 5 %}

<section class="bg-wu-brown grid grid-flow-row text-wu-blue">
  <div class="grid sm:grid-cols-2">
    <div class="p-2 sm:p-10">
      <h1 class="uppercase text-[30px] tracking-[0.2em] pb-2">{{ blog.title }}</h1>
      <div class="blog-description font-serif text-[27px] lg:text-[40px] leading-[35px] md:leading-[48px]">
      {% if pages[blog.handle]%}{{ pages[blog.handle].content }}{% endif %}
      </div>
    </div>
    <div class="bg-wu-red aspect-h-3 aspect-w-3 sm:aspect-w-5 lg:aspect-w-6">

    </div>    

  </div>

{% for article in blog.articles | sort: 'published_at' %}
  {% assign article_content_test = article.content | strip_html | replace: '&nbsp;', '' | strip %}
  {% if article_content_test == '' and article.image %} 
  <article class="border-t border-wu-nav grid  {%if article.image %} sm:grid-cols-3 {% endif%}" x-hey>
    <div class="w-full aspect-w-2 aspect-h-1 col-span-3">
      <img class="object-cover w-full" src="{{ article.image.src | img_url: 'x1600' }}">
    </div>
  </article> 
  {% else %}

  <article class="border-t border-wu-nav grid  {%if article.image %} sm:grid-cols-3 {% endif%}">
    {% if article.image %}
    <div class="w-full aspect-w-2 aspect-h-1 col-span-2">
      <img class="object-cover w-full" src="{{ article.image.src | img_url: 'x1600' }}">
    </div>
    {% endif %}
    <div class="content p-2 sm:p-10">
      <h2 class="text-[30px] tracking-[0.2em] uppercase pb-2">{{ article.title }}</h2>
      <div class="prose font-serif text-[16px] lg:text-[18px] leading-[23px] md:leading-[27px] {%unless article.image%} sm:columns-3 {% endunless%}">
        {{article.content}}
      </div>
    </div>
  </article>
  {%endif%}
{% endfor %}

{% if paginate.pages > 1 %}
  {{ paginate | default_pagination }}
{% endif %}

</section>

{% endpaginate %}
