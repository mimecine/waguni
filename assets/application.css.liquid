
:root {
    --main-bg-color: {{ settings.main_bg_color | default:"var(--nav)" }};
    --text: {{ settings.color_text | default:"var(--white)" }};
    --nav: {{ settings.color_nav | default:"#0055D6" }};
    --red: {{ settings.color_red | default:"#DD343B" }};
    --green: {{ settings.color_green | default:"#009444" }};
    --blue: {{ settings.color_blue | default:"#2000CD" }};
    --yellow: {{ settings.color_yellow | default:"#FBCC03" }};
    --turquoise: {{ settings.color_turquoise | default:"#1BBDBD" }};
    --brown: {{ settings.color_brown | default:"#D6C8AB" }};
    --gray: {{ settings.color_gray | default:"#BBBBBB" }};
    --white: {{ settings.color_white | default:"#FFFFFF" }};
    --black: {{ settings.color_black | default:"#000000" }};
    --splash-bg-desktop: url( '{{ settings.desktop_splash | img_url:'x2048', format:'pjpg' }}' );
    --splash-bg-mobile: url( '{{ settings.mobile_splash | img_url:'1024x', format:'pjpg' }}' );
}
